":null,\"joined_group\":{\"id\":564284136,\"parent_mrk_id\":7981804578,\"wpml_trans_unit_id\":\"wpml_trans_unit__37__40\",\"minimized_artifacts\":{},\"word_count\":34,\"children\":[{\"id\":7981804578,\"signature\":\"0187c0fcd9435b08a911a6ed93c6672b\",\"word_count\":22,\"trans_unit_id\":\"wpml_trans_unit_55_0_37__39\",\"target_content\":\"*Ideal for Romance &amp; Family Fun* 👨‍👩‍👧‍👦<br/>Couples love the romantic candlelight atmosphere, while families appreciate the engaging activities for all ages.\",\"original_content\":\"*Ideal for Romance &amp; Family Fun* 👨‍👩‍👧‍👦<br/>Couples love the romantic candlelight atmosphere, while families appreciate the engaging activities for all ages.\"},{\"id\":7981804579,\"signature\":\"5bd185dfbfcfd462df2d166adce19354\",\"word_count\":12,\"trans_unit_id\":\"wpml_trans_unit_55_0_40\",\"target_content\":\"This desert tour truly offers something special for every type of traveler.\",\"original_content\":\"This desert tour truly offers something special for every type of traveler.\"}],\"is_autojoined\":true}},{\"id\":7981804580,\"status\":3,\"original_content\":\"Why People Love This Trip\",\"translated_content\":\"为什么人们喜欢这次旅行\",\"trans_unit_id\":\"wpml_trans_unit_56_0_0\",\"context\":\"\",\"word_count\":5,\"unclear\":false,\"kind\":\"seg\",\"extras\":{\"type\":\"custom_field\",\"unit\":\"\",\"group\":\"Custom Fields\",\"xpath\":\"text()\",\"page_id\":96141087,\"group_id\":\"Custom_Fields-0\",\"html_tags\":[],\"main_html_tag\":null,\"wpml_suggested_tm\":true},\"updated_at\":\"2026-03-18T23:31:04.000Z\",\"created_at\":\"2026-03-18T23:31:04.000Z\",\"minimized_artifacts\":null,\"missing_markers\":[],\"credits_count\":5,\"can_join_to\":null},{\"id\":7981804581,\"status\":1,\"original_content\":\"Highlights\",\"translated_content\":\"亮点\",\"trans_unit_id\":\"wpml_trans_unit_57_0_0\",\"context\":\"\",\"word_count\":1,\"unclear\":false,\"kind\":\"seg\",\"extras\":{\"type\":\"custom_field\",\"unit\":\"\",\"group\":\"Custom Fields\",\"xpath\":\"text()\",\"page_id\":96141087,\"group_id\":\"Custom_Fields-0\",\"html_tags\":[],\"main_html_tag\":null,\"wpml_suggested_tm\":true},\"updated_at\":\"2026-03-18T23:31:04.000Z\",\"created_at\":\"2026-03-18T23:31:04.000Z\",\"minimized_artifacts\":null,\"missing_markers\":[],\"credits_count\":1,\"can_join_to\":null},{\"id\":7981804582,\"status\":1,\"original_content\":\"Learn the art of Bedouin bread baking over hot coals, then savor it fresh with your BBQ dinner under the starry desert sky.\",\"translated_content\":\"学习在炽热炭火上烘焙贝都因面包的艺术，然后在繁星点点的沙漠天空下享用新鲜出炉的面包搭配烧烤晚餐。\",\"trans_unit_id\":\"wpml_trans_unit_58_0_0\",\"context\":\"\",\"word_count\":23,\"unclear\":false,\"kind\":\"seg\",\"extras\":{\"type\":\"custom_field\",\"unit\":\"\",\"group\":\"Custom Fields\",\"xpath\":\"text()\",\"page_id\":96141087,\"group_id\":\"Custom_Fields-0\",\"html_tags\":[],\"main_html_tag\":null,\"wpml_suggested_tm\":true},\"updated_at\":\"2026-03-18T23:31:04.000Z\",\"created_at\":\"2026-03-18T23:31:04.000Z\",\"minimized_artifacts\":null,\"missing_markers\":[],\"credits_count\":23,\"can_join_to\":null},{\"id\":7981804583,\"status\":1,\"original_content\":\"Watch traditional Bedouin performers bring desert culture to life through captivating dance and music around the campfire.\",\"translated_content\":\"观看传统贝都因表演者围绕篝火，通过迷人的舞蹈和音乐将沙漠文化生动呈现。\",\"trans_unit_id\":\"wpml_trans_unit_59_0_0\",\"context\":\"\",\"word_count\":17,\"unclear\":false,\"kind\":\"seg\",\"extras\":{\"type\":\"custom_field\",\"unit\":\"\",\"group\":\"Custom Fields\",\"xpath\":\"text()\",\"page_id\":96141087,\"group_id\":\"Custom_Fields-0\",\"html_tags\":[],\"main_html_tag\":null,\"wpml_suggested_tm\":true},\"updated_at\":\"2026-03-18T23:31:04.000Z\",\"created_at\":\"2026-03-18T23:31:04.000Z\",\"minimized_artifacts\":null,\"missing_markers\":[],\"credits_count\":17,\"can_join_to\":null},{\"id\":7981804584,\"status\":1,\"original_content\":\"Ride a camel through golden dunes at sunset, feeling the desert's vast silence before arriving at your welcoming Bedouin camp.\",\"translated_content\":\"在日落时分骑骆驼穿越金色沙丘，感受沙漠的浩瀚宁静，然后抵达热情好客的贝都因营地。\",\"trans_unit_id\":\"wpml_trans_unit_60_0_0\",\"context\":\"\",\"word_count\":20,\"unclear\":false,\"kind\":\"seg\",\"extras\":{\"type\":\"custom_field\",\"unit\":\"\",\"group\":\"Custom Fields\",\"xpath\":\"text()\",\"page_id\":96141087,\"group_id\":\"Custom_Fields-0\",\"html_tags\":[],\"main_html_tag\":null,\"wpml_suggested_tm\":true},\"updated_at\":\"2026-03-18T23:31:04.000Z\",\"created_at\":\"2026-03-18T23:31:04.000Z\",\"minimized_artifacts\":null,\"missing_markers\":[],\"credits_count\":20,\"can_join_to\":null},{\"id\":7981804585,\"status\":1,\"original_content\":\"Explore distant galaxies through high-powered telescopes with expert guides who reveal celestial wonders invisible to the naked eye.\",\"translated_content\":\"通过高倍望远镜探索遥远星系，专业向导将揭示肉眼无法看见的宇宙奇观。\",\"trans_unit_id\":\"wpml_trans_unit_61_0_0\",\"context\":\"\",\"word_count\":19,\"unclear\":false,\"kind\":\"seg\",\"extras\":{\"type\":\"custom_field\",\"unit\":\"\",\"group\":\"Custom Fields\",\"xpath\":\"text()\",\"page_id\":96141087,\"group_id\":\"Custom_Fields-0\",\"html_tags\":[],\"main_html_tag\":null,\"wpml_suggested_tm\":true},\"updated_at\":\"2026-03-18T23:31:04.000Z\",\"created_at\":\"2026-03-18T23:31:04.000Z\",\"minimized_artifacts\":null,\"missing_markers\":[],\"credits_count\":19,\"can_join_to\":null},{\"id\":7981804586,\"status\":1,\"original_content\":\"Feel the desert's thrill on an optional quad bike ride across rolling dunes, adding an adventurous rush to your evening under the stars.\",\"translated_content\":\"选择四轮摩托车在起伏的沙丘上驰骋，感受沙漠的刺激，为星空下的夜晚增添冒险的兴奋。\",\"trans_unit_id\":\"wpml_trans_unit_62_0_0\",\"context\":\"\",\"word_count\":23,\"unclear\":false,\"kind\":\"seg\",\"extras\":{\"type\":\"custom_field\",\"unit\":\"\",\"group\":\"Custom Fields\",\"xpath\":\"text()\",\"page_id\":96141087,\"group_id\":\"Custom_Fields-0\",\"html_tags\":[],\"main_html_tag\":null,\"wpml_suggested_tm\":true},\"updated_at\":\"2026-03-18T23:31:04.000Z\",\"created_at\":\"2026-03-18T23:31:04.000Z\",\"minimized_artifacts\":null,\"missing_markers\":[],\"credits_count\":23,\"can_join_to\":null},{\"id\":7981804587,\"status\":1,\"original_content\":\"Savor five hot traditional dishes alongside seasonal fruits, enjoying authentic flavors in the open desert air as the campfire crackles nearby.\",\"translated_content\":\"品尝五道热腾腾的传统菜肴和时令水果，在开阔的沙漠空气中享受地道风味，篝火在旁噼啪作响。\",\"trans_unit_id\":\"wpml_trans_unit_63_0_0\",\"context\":\"\",\"word_count\":21,\"unclear\":false,\"kind\":\"seg\",\"extras\":{\"type\":\"custom_field\",\"unit\":\"\",\"group\":\"Custom Fields\",\"xpath\":\"text()\",\"page_id\":96141087,\"group_id\":\"Custom_Fields-0\",\"html_tags\":[],\"main_html_tag\":null,\"wpml_suggested_tm\":true},\"updated_at\":\"2026-03-18T23:31:04.000Z\",\"created_at\":\"2026-03-18T23:31:04.000Z\",\"minimized_artifacts\":null,\"missing_markers\":[],\"credits_count\":21,\"can_join_to\":null},{\"id\":7981804588,\"status\":1,\"original_content\":\"Wrap yourself in an authentic Egyptian scarf for stylish desert flair and essential protection from sun and sand during your adventure.\",\"translated_content\":\"裹上一条正宗的埃及围巾，既增添时尚的沙漠风情，又能在冒险中有效防晒防沙。\",\"trans_unit_id\":\"wpml_trans_unit_64_0_0\",\"context\":\"\",\"word_count\":21,\"unclear\":false,\"kind\":\"seg\",\"extras\":{\"type\":\"custom_field\",\"unit\":\"\",\"group\":\"Custom Fields\",\"xpath\":\"text()\",\"page_id\":96141087,\"group_id\":\"Custom_Fields-0\",\"html_tags\":[],\"main_html_tag\":null,\"wpml_suggested_tm\":true},\"updated_at\":\"2026-03-18T23:31:04.000Z\",\"created_at\":\"2026-03-18T23:31:04.000Z\",\"minimized_artifacts\":null,\"missing_markers\":[],\"credits_count\":21,\"can_join_to\":null},{\"id\":7981804589,\"status\":1,\"original_content\":\"Listen to captivating stories of desert life and Bedouin traditions from your experienced guide around the warm campfire.\",\"translated_content\":\"围绕温暖的篝火，聆听经验丰富的向导讲述沙漠生活和贝都因传统的迷人故事。\",\"trans_unit_id\":\"wpml_trans_unit_65_0_0\",\"context\":\"\",\"word_count\":18,\"unclear\":false,\"kind\":\"seg\",\"extras\":{\"type\":\"custom_field\",\"unit\":\"\",\"group\":\"Custom Fields\",\"xpath\":\"text()\",\"page_id\":96141087,\"group_id\":\"Custom_Fields-0\",\"html_tags\":[],\"main_html_tag\":null,\"wpml_suggested_tm\":true},\"updated_at\":\"2026-03-18T23:31:04.000Z\",\"created_at\":\"2026-03-18T23:31:04.000Z\",\"minimized_artifacts\":null,\"missing_markers\":[],\"credits_count\":18,\"can_join_to\":null},{\"id\":7981804590,\"status\":1,\"original_content\":\"Capture the desert's golden hour glow during a guided photography session, learning to frame perfect sunset shots against endless dunes.\",\"translated_content\":\"在指导性的摄影环节中捕捉沙漠黄金时分的绚丽光芒，学习如何以无垠沙丘为背景拍摄完美的日落照片。\",\"trans_unit_id\":\"wpml_trans_unit_66_0_0\",\"context\":\"\",\"word_count\":20,\"unclear\":false,\"kind\":\"seg\",\"extras\":{\"type\":\"custom_field\",\"unit\":\"\",\"group\":\"Custom Fields\",\"xpath\":\"text()\",\"page_id\":96141087,\"group_id\":\"Custom_Fields-0\",\"html_tags\":[],\"main_html_tag\":null,\"wpml_suggested_tm\":true},\"updated_at\":\"2026-03-18T23:31:04.000Z\",\"created_at\":\"2026-03-18T23:31:04.000Z\",\"minimized_artifacts\":null,\"missing_markers\":[],\"credits_count\":20,\"can_join_to\":null},{\"id\":7981804591,\"status\":1,\"original_content\":\"Sip a refreshing soft drink as the sun dips below the dunes, painting the desert sky in brilliant shades of orange and purple.\",\"translated_content\":\"啜饮清爽的软饮，看着太阳沉入沙丘之下，将沙漠天空染成绚丽的橙紫色调。\",\"trans_unit_id\":\"wpml_trans_unit_67_0_0\",\"context\":\"\",\"word_count\":23,\"unclear\":false,\"kind\":\"seg\",\"extras\":{\"type\":\"custom_field\",\"unit\":\"\",\"group\":\"Custom Fields\",\"xpath\":\"text()\",\"page_id\":96141087,\"group_id\":\"Custom_Fields-0\",\"html_tags\":[],\"main_html_tag\":null,\"wpml_suggested_tm\":true},\"updated_at\":\"2026-03-18T23:31:04.000Z\",\"created_at\":\"2026-03-18T23:31:04.000Z\",\"minimized_artifacts\